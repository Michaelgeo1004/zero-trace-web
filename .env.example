# Public site URL (no trailing slash) — used for metadata, sitemap, robots
NEXT_PUBLIC_SITE_URL=https://zerotrace.events

# Resend (https://resend.com) — optional until you verify a sending domain
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=you@yourdomain.com
# Must be a verified sender in Resend (or Resend onboarding address for testing)
RESEND_FROM_EMAIL=Zero Trace <onboarding@resend.dev>
